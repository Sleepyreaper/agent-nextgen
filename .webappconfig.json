{
  "name": "NextGen Agent System",
  "description": "Azure AI-powered application evaluation system",
  "version": "1.0.0",
  "runtime": {
    "name": "Python",
    "version": "3.11"
  },
  "startup": {
    "type": "wsgi",
    "wsgi_app": "wsgi:app",
    "workers": 2,
    "worker_class": "gthread",
    "threads": 4,
    "timeout": 600,
    "access_log": true,
    "error_log": true
  },
  "requirements": {
    "python": ">=3.11",
    "pip": "requirements.txt"
  },
  "env": {
    "AZURE_KEY_VAULT_NAME": "your-keyvault-name",
    "FLASK_ENV": "production",
    "GUNICORN_WORKERS": "2"
  },
  "health_check": {
    "enabled": true,
    "path": "/"
  }
}
