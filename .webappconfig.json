{
  "name": "NextGen Agent System",
  "description": "Azure AI-powered application evaluation system",
  "version": "1.0.0",
  "runtime": {
    "name": "Python",
    "version": "3.11"
  },
  "startup": {
    "type": "wsgi",
    "wsgi_app": "wsgi:app",
    "note": "Actual values are in gunicorn.conf.py (single source of truth), overridable via env vars",
    "workers": "env GUNICORN_WORKERS (default: 4)",
    "threads": "env GUNICORN_THREADS (default: 4)",
    "timeout": "env GUNICORN_TIMEOUT (default: 120)",
    "access_log": true,
    "error_log": true
  },
  "requirements": {
    "python": ">=3.11",
    "pip": "requirements.txt"
  },
  "env": {
    "AZURE_KEY_VAULT_NAME": "your-keyvault-name",
    "FLASK_ENV": "production",
    "GUNICORN_WORKERS": "2"
  },
  "health_check": {
    "enabled": true,
    "path": "/"
  }
}
